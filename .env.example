# ---- Core ----
PORT=8080
# Interface to bind. 0.0.0.0 = all interfaces (external IP reachable).
HOST=0.0.0.0

# Anthropic API key — REQUIRED. Powers the child-safety moderation engine
# and the Claude Code (vibe-coding) provider.
ANTHROPIC_API_KEY=

# ---- Moderation engine ----
# Model used to classify every inbound prompt and every outbound result for
# child safety. Default is the most capable model because, for child safety,
# correctness matters more than cost/latency. For lower latency/cost on
# high request volumes you can drop to claude-haiku-4-5 (faster, slightly
# less nuanced).
MODERATION_MODEL=claude-opus-4-8

# Reasoning effort for moderation: low | medium | high
# 'low' keeps the safety check fast; raise it if you want deeper judgment.
MODERATION_EFFORT=low

# If a moderation call itself errors (network/API), what should happen?
# true  = fail CLOSED  -> block the request (safe default for children)
# false = fail OPEN    -> allow the request through
FAIL_CLOSED=true

# ---- Concurrency ----
# Max HTTP requests served concurrently. Requests beyond this queue briefly.
MAX_CONCURRENT_REQUESTS=10
# Requests rejected with 503 once the queue grows past this.
MAX_QUEUE=50
# Max in-flight moderation calls to the Anthropic API at once.
MAX_MODERATION_CONCURRENCY=16

# ---- Authentication ----
# The primary account. There is no sign-up; these are the only credentials.
AUTH_USERNAME=HarborHouse
AUTH_PASSWORD=hhai123!
# Additional accounts, as a comma-separated "username:password" list. Passwords
# may not contain a comma. Example:
# AUTH_ADDITIONAL_USERS=HarborHouse1:hhai123!,HarborHouse2:hhai123!
AUTH_ADDITIONAL_USERS=
# How long a login session stays valid.
SESSION_TTL_HOURS=12
# Set true when serving over HTTPS so the session cookie is marked Secure.
COOKIE_SECURE=false

# ---- Operator review area (ADULTS ONLY) ----
# Optional audit console at /review that can display generated content the
# child-safety filter BLOCKED, alongside the reason it was blocked. It is fully
# disabled (404) unless REVIEW_PASSWORD is set, uses its own separate password
# and cookie/session, and is never linked from the child-facing UI.
# WARNING: anyone with this password can view content that failed the child
# safety checks (adult/racy/violence). Keep it secret; leave blank to disable.
REVIEW_PASSWORD=
# How long an unlocked operator review session stays valid.
REVIEW_SESSION_TTL_HOURS=4

# ---- Providers (all optional; a route returns 501 until its key is set) ----
# Suno (music generation)
SUNO_API_KEY=
SUNO_BASE_URL=https://api.suno.ai

# ElevenLabs (voice generation / voice transfer)
ELEVENLABS_API_KEY=
ELEVENLABS_BASE_URL=https://api.elevenlabs.io

# ---- Storybook illustrations ----
# Which engine paints storybook pictures:
#   replicate = "Nano Banana Pro" (Google Gemini 3 Pro Image) via Replicate —
#               higher quality; uses up to 14 reference images for character/
#               object/setting consistency across a book. (default)
#   gemini    = "Nano Banana 2" (Gemini 3.1 Flash Image) direct — cheaper.
# Switch to gemini to save money.
STORY_IMAGE_PROVIDER=replicate

# Replicate — hosts Nano Banana Pro (the default engine). Get a token at
# https://replicate.com/account/api-tokens. If this is unset the app falls back
# to the Gemini engine (when GEMINI_API_KEY is set).
REPLICATE_API_TOKEN=
REPLICATE_BASE_URL=https://api.replicate.com
REPLICATE_IMAGE_MODEL=google/nano-banana-pro
# Output resolution: 1K | 2K | 4K. Lower is cheaper; pages display small.
REPLICATE_IMAGE_RESOLUTION=2K
# Nano Banana Pro's own safety gate (on top of our moderation + Vision):
# block_low_and_above | block_medium_and_above | block_only_high
REPLICATE_SAFETY_FILTER=block_low_and_above

# Google Gemini — "Nano Banana 2" (text-to-image), the cheaper engine.
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image

# Google Cloud Vision SafeSearch — screens every generated image before it is
# shown. Auth: VISION_API_KEY if set; otherwise Application Default Credentials
# (gcloud auth application-default login) or the GCE metadata service account.
VISION_API_KEY=
VISION_BASE_URL=https://vision.googleapis.com
# Block when adult/racy/violence likelihood >= this: POSSIBLE | LIKELY | VERY_LIKELY
SAFESEARCH_BLOCK_AT=POSSIBLE

# Claude Code provider uses ANTHROPIC_API_KEY above.
CLAUDE_CODE_MODEL=claude-opus-4-8
