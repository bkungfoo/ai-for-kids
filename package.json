{
  "name": "child-safe-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Lightweight child-safety gateway: moderates text in and out before/after calling generative AI providers.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "ui-check": "node scripts/ui-design-check.mjs",
    "ui-spacing-check": "tsx scripts/ui-spacing-check.mts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.23",
    "@types/node": "^22.10.0",
    "playwright-core": "^1.61.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
